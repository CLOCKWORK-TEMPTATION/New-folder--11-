# ============================================
# Universal Prompt Optimizer - Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys

# --- LLM Provider API Keys ---
# At least ONE key is required for the system to work.

# Google Gemini (for gemini-3.1-pro)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (for gpt-5.5)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (for opus-4.7)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/prompt_optimizer
REDIS_URL=redis://localhost:6379

# --- Application ---
API_PORT=8000
FRONTEND_URL=http://localhost:3000
