{
  "name": "promptoptima-vscode",
  "displayName": "PromptOptima",
  "description": "Universal Prompt Optimizer VS Code Extension",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptoptima.optimizeUserPrompt",
        "title": "PromptOptima: Optimize Selected User Prompt"
      },
      {
        "command": "promptoptima.auditSystemPrompt",
        "title": "PromptOptima: Audit Selected System Prompt"
      },
      {
        "command": "promptoptima.scanCode",
        "title": "PromptOptima: Scan Current File for Code Prompts"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out"
  },
  "dependencies": {
    "axios": "^1.6.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
